{
    "PORT": 3456,
    "HOST": "127.0.0.1",
    "API_TIMEOUT_MS": 600000,
    "Persistence": {
        "_comment": "Optional metrics/dashboard persistence. Set mode=redis to survive server restarts.",
        "mode": "none",
        "redis_url": "redis://127.0.0.1:6379/0",
        "redis_prefix": "ccr-rust:persistence:v1"
    },
    "Providers": [
        {
            "name": "deepseek",
            "api_base_url": "https://api.deepseek.com",
            "api_key": "${DEEPSEEK_API_KEY}",
            "models": [
                "deepseek-reasoner",
                "deepseek-chat"
            ]
        },
        {
            "name": "minimax",
            "api_base_url": "https://api.minimax.io/v1",
            "api_key": "${MINIMAX_API_KEY}",
            "models": [
                "MiniMax-M2.7"
            ],
            "transformer": {
                "use": [
                    "minimax"
                ]
            }
        },
        {
            "name": "openrouter",
            "api_base_url": "https://openrouter.ai/api/v1",
            "api_key": "${OPENROUTER_API_KEY}",
            "models": [
                "openrouter/aurora-alpha"
            ],
            "transformer": {
                "use": [
                    "anthropic",
                    "openrouter"
                ]
            }
        },
        {
            "name": "qwen",
            "_comment": "Alibaba Cloud Model Studio Coding Plan. Use coding-intl.dashscope.aliyuncs.com for subscription plans (sk-sp-xxx keys). Standard DashScope keys (sk-xxx) use dashscope-intl.aliyuncs.com.",
            "api_base_url": "https://coding-intl.dashscope.aliyuncs.com/v1",
            "api_key": "${QWEN_API_KEY}",
            "models": [
                "qwen3-coder-next",
                "qwen3.5-plus"
            ],
            "transformer": {
                "use": [
                    "anthropic"
                ]
            },
            "tier_name": "ccr-qwen"
        },
        {
            "name": "wafer",
            "_comment": "Wafer Unlimited — optimized Qwen3.5-397B-A17B. Flat rate, no per-token cost.",
            "api_base_url": "https://pass.wafer.ai/v1",
            "api_key": "${WAFER_API_KEY}",
            "models": [
                "Qwen3.5-397B-A17B"
            ],
            "transformer": {
                "use": [
                    "anthropic",
                    [
                        "toolcompress",
                        {
                            "level": "medium"
                        }
                    ],
                    "output_compress"
                ]
            },
            "tier_name": "ccr-wafer"
        }
    ],
    "Router": {
        "default": "wafer,Qwen3.5-397B-A17B",
        "background": "deepseek,deepseek-chat",
        "tiers": [
            "wafer,Qwen3.5-397B-A17B",
            "deepseek,deepseek-reasoner",
            "minimax,MiniMax-M2.7",
            "openrouter,openrouter/aurora-alpha"
        ]
    },
    "Presets": {
        "coding": {
            "route": "deepseek,deepseek-chat",
            "temperature": 0.7
        },
        "reasoning": {
            "route": "deepseek,deepseek-reasoner"
        },
        "documentation": {
            "route": "deepseek,deepseek-chat"
        }
    },
    "Frontend": {
        "_comment": "Configuration for frontend-specific behaviors",
        "codex": {
            "_comment": "Settings for the Codex/OpenAI compatible endpoint",
            "modelMappings": {
                "_comment": "Maps model names requested by the client to specific provider models. 'default' is used if no mapping matches.",
                "default": "o3-mini",
                "o3-mini": "o3-mini",
                "gpt-4o": "gpt-4o",
                "o1": "o1"
            }
        },
        "claudeCode": {
            "_comment": "Settings for Claude Code specific features (optional)",
            "cachePreferences": {
                "_comment": "Controls server-side caching for system prompts to reduce latency.",
                "promptCaching": true,
                "maxCacheAgeHours": 24
            }
        }
    }
}